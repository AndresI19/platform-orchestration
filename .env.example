# Copy to .env (gitignored) and fill in.
#
# IMPORTANT: .env is no longer read at runtime. Nothing in the cluster loads it. The platform's
# secrets are SEALED into k8s/base/sealed-*.yaml and k8s/overlays/public/sealed-cloudflared.yaml,
# and its non-secret config lives in k8s/base/config.yaml (VMCP_API_BASE, CORS_ORIGINS, HOME_URL,
# FVT_INTERVAL_SECONDS — all patched to their public values by the public overlay).
#
# This file is now only the PLAINTEXT SOURCE you re-seal from when a credential changes:
#
#   kubectl create secret generic cloudflared -n platform --dry-run=client -o yaml \
#     --from-literal=TUNNEL_TOKEN="$(grep '^CLOUDFLARE_TUNNEL_TOKEN=' .env | cut -d= -f2-)" \
#     | kubeseal --format yaml --controller-namespace kube-system \
#     > k8s/overlays/public/sealed-cloudflared.yaml
#
# The sealed files are encrypted with the cluster's public key and are safe to commit. This one is
# not, and is gitignored.

# Discord webhook that receives the home page's optional "Who are you?" greeting.
# Server Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL.
# Unset, the home server logs the greeting to its stdout instead of dropping it.
#   → sealed into k8s/base/sealed-platform-secrets.yaml
DISCORD_WEBHOOK_URL=

# Where systemd/platform-boot.sh announces "booting" / "up" / "boot FAILED" after a reboot.
# This one is NOT sealed and is NOT read by anything in the cluster: the boot script runs on the HOST,
# before the cluster exists, so it reads this file directly. Leave it blank to share the greeting
# webhook above; with both blank the script logs the message and carries on — a missing webhook never
# fails a boot.
PLATFORM_BOOT_WEBHOOK_URL=

# From Cloudflare Zero Trust → Networks → Tunnels → (your tunnel) → Install connector.
# It is a credential: anyone holding it can serve traffic as your tunnel.
#   → sealed into k8s/overlays/public/sealed-cloudflared.yaml
CLOUDFLARE_TUNNEL_TOKEN=

# The Postgres password is GENERATED, not chosen: it is rotated with `ALTER USER` inside the running
# database and sealed into k8s/base/sealed-vmcp-db.yaml. It is deliberately absent here — there is no
# reason for a second plaintext copy of it to sit on disk.
